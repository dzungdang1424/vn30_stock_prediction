# =============================================================================
# Environment Variables — vn30_stock_prediction
# =============================================================================
# Hướng dẫn:
#   1. Copy file này: cp .env.example .env
#   2. Điền API key thật của bạn vào file .env
#   3. KHÔNG commit file .env lên Git
# =============================================================================

# -----------------------------------------------------------------------------
# Google Gemini API (LLM Agent)
# -----------------------------------------------------------------------------
# Lấy miễn phí tại: https://aistudio.google.com/app/apikey
# Không cần credit card. Rate limit free tier: ~15 RPM, ~1500 RPD
# -----------------------------------------------------------------------------
GEMINI_API_KEY=your_gemini_api_key_here

# -----------------------------------------------------------------------------
# Vnstock API Key (Data Collection)
# -----------------------------------------------------------------------------
# Dùng cho vnstock_data (Sponsored/Community version — Unified UI)
# Xem hướng dẫn lấy key tại: https://docs.vnstock.site
# -----------------------------------------------------------------------------
VNSTOCK_API_KEY=your_vnstock_api_key_here
